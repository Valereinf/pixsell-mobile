{
  "expo": {
    "name": "Pixsell",
    "slug": "pixsell-mobile",
    "version": "1.0.1",
    "scheme": "pixsell",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "backgroundColor": "#000099",
      "resizeMode": "contain"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pixsell.mobile",
      "backgroundColor": "#000099",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#000099",
      "translucent": false
    },
    "ios": {
      "bundleIdentifier": "com.pixsell.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#6B46C1",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75fe8240-fe07-4514-954e-7cdbc77af6ff"
      }
    }
  }
}

{
  "expo": {
    "name": "Pixsell",
    "slug": "pixsell-mobile",
    "version": "1.0.0",
    "scheme": "pixsell",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.pixsell.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.pixsell.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}

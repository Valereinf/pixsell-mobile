{
  "expo": {
    "name": "Pixsell",
    "slug": "pixsell-mobile",
    "version": "1.0.0",
    "scheme": "pixsell",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": [
      "ios",
      "android"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.pixsell.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.pixsell.mobile",
      "supportsTablet": true
    },
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "75fe8240-fe07-4514-954e-7cdbc77af6ff"
      }
    }
  }
}
